# Web App Environment Variables

# Environment
NODE_ENV=development

# API URLs (REQUIRED - these are baked into Next.js build)
# These must start with NEXT_PUBLIC_ to be available in the browser
# In production, set these in your deployment platform (Vercel, etc.) before building

# For local development:
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_AI_SERVICE_URL=http://localhost:3002

# For production:
# NEXT_PUBLIC_API_URL=https://api.yourdomain.com
# NEXT_PUBLIC_AI_SERVICE_URL=https://ai.yourdomain.com

# Analytics Configuration (Optional)
# Set NEXT_PUBLIC_ANALYTICS_PROVIDER to "plausible" or "posthog" to enable analytics
# Leave unset for no analytics (safe for development)

# Plausible Analytics
# NEXT_PUBLIC_ANALYTICS_PROVIDER=plausible
# NEXT_PUBLIC_ANALYTICS_SITE_ID=your-plausible-site-id

# PostHog Analytics
# NEXT_PUBLIC_ANALYTICS_PROVIDER=posthog
# NEXT_PUBLIC_POSTHOG_KEY=your-posthog-project-api-key
# NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# Note: These are build-time variables. They must be set before running `pnpm build`.
# On Vercel, set them in the dashboard under Settings > Environment Variables.
# On container-based hosting, set them as build args or environment variables.
