# Root environment variables
# These are used across all apps

# Environment
NODE_ENV=development

# Base URLs (for local development)
# In production, set these to your actual domain URLs
API_BASE_URL=http://localhost:3001
WEB_BASE_URL=http://localhost:3000
AI_SERVICE_URL=http://localhost:3002

# Database (for local development with docker-compose)
# In production, use managed database and set DATABASE_URL in apps/api/.env
DATABASE_URL=postgresql://novafans:novafans@localhost:5432/novafans

# Redis (for local development with docker-compose)
# In production, use managed Redis and set REDIS_URL in apps/api/.env
REDIS_URL=redis://localhost:6379

# Crypto Payment Gateway (optional - defaults to fake mode)
# See apps/api/.env.example for full configuration
# CRYPTO_PROVIDER=fake
# CRYPTO_API_KEY=
# CRYPTO_WEBHOOK_SECRET=
# CRYPTO_CALLBACK_BASE_URL=http://localhost:3001
# CRYPTO_DEFAULT_CURRENCY=USDT
